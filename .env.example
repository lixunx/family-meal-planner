# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: timezone for helper guest view (no login)
NEXT_PUBLIC_DEFAULT_TIMEZONE=Asia/Singapore

# Initial admin emails (comma-separated, first login gets admin role)
INITIAL_ADMIN_EMAILS=you@example.com,wife@example.com
